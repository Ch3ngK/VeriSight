{
    "manifest_version": 3,
    "name": "VeriSight",
    "version": "0.1.0",
    "description": "Credibility signals + claim extraction for YouTube videos.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "VeriSight"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}
